# MongoDB connection string (get free one from MongoDB Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/digitalsoft_leads

# Port for the backend server
PORT=5000

# Secret key used to sign login tokens (make this a long random string)
JWT_SECRET=change_this_to_a_long_random_secret_string

# Organizer info used inside .ics calendar invites
ORGANIZER_NAME=DigitalSoft Team
ORGANIZER_EMAIL=meetings@digitalsoft.com

# Optional: AI Lead Summary feature (leave blank to use mock summaries)
GEMINI_API_KEY=
